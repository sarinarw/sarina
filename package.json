{
  "name": "sarinawhite",
  "version": "1.0.0",
  "description": "Sarina White's personal site",
  "scripts": {
    "dev": "concurrently \"npx @11ty/eleventy --serve --incremental\" \"postcss src/assets/styles/main.css -o _site/assets/styles/main.css --watch\"",
    "build": "npx @11ty/eleventy && postcss src/assets/styles/main.css -o _site/assets/styles/main.css && npx pagefind --site _site --output-subdir _pagefind",
    "clean": "rimraf _site",
    "format": "prettier '**/*.{js,json,njk,md}' --write --ignore-path .prettierignore"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "cssnano": "^7.0.0",
    "pagefind": "^1.3.0",
    "postcss": "^8.4.0",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "tailwindcss": "^3.4.0"
  }
}
